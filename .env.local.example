# Supabase — copie este arquivo como .env.local e preencha com suas credenciais
# Encontre os valores em: https://supabase.com/dashboard → seu projeto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — usada apenas no servidor (magic link, deleção de conta)
# Encontre em: Supabase → Settings → API → service_role key (NUNCA exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL canônica de produção — usada nos redirects de auth (magic link, Google OAuth)
NEXT_PUBLIC_SITE_URL=https://www.gamellitoltda.com.br

# Resend — serviço de envio de e-mail (magic link customizado)
# Crie uma conta em https://resend.com e adicione o domínio gamellitoltda.com.br
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=diario@gamellitoltda.com.br

