{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "${SUPABASE_ACCESS_TOKEN}"
      ]
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "@vercel/mcp-server"],
      "env": {
        "VERCEL_ACCESS_TOKEN": "${VERCEL_TOKEN}",
        "VERCEL_PROJECT_ID": "prj_n1lB2o9e5lWZTRZOPLa7mqDZ3pXg"
      }
    }
  }
}
